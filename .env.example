# ============================================================================
# Medusa v2 Production Environment Variables
# ============================================================================
# Copy this file to .env for local development
# In Coolify/VPS, set these as environment variables
# ============================================================================

# ----------------------------------------------------------------------------
# SECURITY SECRETS (REQUIRED)
# ----------------------------------------------------------------------------
# Generate secure random strings for production
# Use: openssl rand -base64 32
COOKIE_SECRET=change-me-to-random-string
JWT_SECRET=change-me-to-random-string

# ----------------------------------------------------------------------------
# CORS SETTINGS (REQUIRED)
# ----------------------------------------------------------------------------
# URLs of your storefront and admin dashboard
# Separate multiple URLs with commas, no spaces
STORE_CORS=http://localhost:3000
ADMIN_CORS=http://localhost:7001,http://localhost:3000
AUTH_CORS=http://localhost:7001,http://localhost:3000

# ----------------------------------------------------------------------------
# MEDUSA CONFIGURATION (REQUIRED)
# ----------------------------------------------------------------------------
# Worker Mode: "server" for API/admin, "worker" for background jobs
# You need TWO deployments: one with "server", one with "worker"
MEDUSA_WORKER_MODE=server

# Disable Admin: Set to "true" for worker deployment, "false" for server
DISABLE_ADMIN=false

# Backend URL: URL of this Medusa server (for admin dashboard communication)
MEDUSA_BACKEND_URL=http://localhost:9000

# Port: Medusa server port (default 9000)
PORT=9000

# ----------------------------------------------------------------------------
# DATABASE (REQUIRED)
# ----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medusa

# ----------------------------------------------------------------------------
# REDIS (REQUIRED)
# ----------------------------------------------------------------------------
# Redis connection string for sessions, events, caching, and locking
# Format: redis://[:password@]host:port/db
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------------------
# FILE STORAGE (OPTIONAL - Recommended for Production)
# ----------------------------------------------------------------------------
# Configure S3 or MinIO for file uploads
# Without this, files are stored locally (not recommended for production)
S3_FILE_URL=https://your-bucket.s3.amazonaws.com
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
S3_ENDPOINT=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key

# ----------------------------------------------------------------------------
# EMAIL NOTIFICATIONS (OPTIONAL)
# ----------------------------------------------------------------------------
# SendGrid for transactional emails
SENDGRID_API_KEY=SG.your-api-key
SENDGRID_FROM=noreply@yourdomain.com

# ----------------------------------------------------------------------------
# NODE ENVIRONMENT
# ----------------------------------------------------------------------------
NODE_ENV=development
